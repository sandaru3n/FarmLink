rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ================================
    // HELPER FUNCTIONS
    // ================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // ================================
    // USERS COLLECTION
    // ================================
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isOwner(userId);
    }
    
    // ================================
    // CROPS COLLECTION
    // ================================
    match /crops/{cropId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && 
        (request.auth.uid == resource.data.farmerId || 
         request.auth.uid == request.resource.data.farmerId);
    }
    
    // ================================
    // BIDS COLLECTION
    // ================================
    match /bids/{bidId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && 
        (request.auth.uid == resource.data.distributorId ||
         request.auth.uid == resource.data.farmerId);
      allow delete: if isAuthenticated() && 
        request.auth.uid == resource.data.distributorId;
    }
    
    // ================================
    // ORDERS COLLECTION
    // ================================
    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        (request.auth.uid == resource.data.distributorId ||
         request.auth.uid == resource.data.farmerId);
      allow delete: if false; // Orders should not be deleted
    }
    
    // ================================
    // DELIVERY ORDERS COLLECTION
    // ================================
    match /delivery_orders/{deliveryOrderId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        (request.auth.uid == resource.data.distributorId ||
         request.auth.uid == resource.data.transporterId);
      allow delete: if false; // Delivery orders should not be deleted
    }
    
    // ================================
    // TRANSPORT ORDERS COLLECTION
    // ================================
    match /transport_orders/{transportOrderId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        (request.auth.uid == resource.data.transporterId ||
         request.auth.uid == resource.data.distributorId);
      allow delete: if false; // Transport orders should not be deleted
    }
    
    // ================================
    // RATINGS COLLECTION (Transporter → Distributor)
    // ================================
    match /ratings/{ratingId} {
      // Anyone authenticated can read ratings
      allow read: if isAuthenticated();
      
      // Transporters can create ratings for distributors
      allow create: if isAuthenticated() &&
        request.resource.data.transporterId == request.auth.uid &&
        request.resource.data.rating is number &&
        request.resource.data.rating >= 0 &&
        request.resource.data.rating <= 5 &&
        request.resource.data.deliveryOrderId is string &&
        request.resource.data.distributorId is string &&
        request.resource.data.createdAt is timestamp;
      
      // Only the transporter who created the rating can update it
      allow update: if isAuthenticated() &&
        resource.data.transporterId == request.auth.uid;
      
      // Only the transporter who created the rating can delete it
      allow delete: if isAuthenticated() &&
        resource.data.transporterId == request.auth.uid;
    }
    
    // ================================
    // CONSUMER RATINGS COLLECTION (Consumer → Distributor)
    // ================================
    match /consumer_ratings/{ratingId} {
      // Anyone authenticated can read ratings
      allow read: if isAuthenticated();
      
      // Consumers can create ratings for distributors
      allow create: if isAuthenticated() &&
        request.resource.data.consumerId == request.auth.uid &&
        request.resource.data.rating is number &&
        request.resource.data.rating >= 0 &&
        request.resource.data.rating <= 5 &&
        request.resource.data.consumerOrderId is string &&
        request.resource.data.distributorId is string &&
        request.resource.data.createdAt is timestamp;
      
      // Only the consumer who created the rating can update it
      allow update: if isAuthenticated() &&
        resource.data.consumerId == request.auth.uid;
      
      // Only the consumer who created the rating can delete it
      allow delete: if isAuthenticated() &&
        resource.data.consumerId == request.auth.uid;
    }
    
    // ================================
    // CONSUMER ORDERS COLLECTION
    // ================================
    match /consumer_orders/{consumerOrderId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        (request.auth.uid == resource.data.consumerId ||
         request.auth.uid == resource.data.distributorId);
      allow delete: if false; // Consumer orders should not be deleted
    }
    
    // ================================
    // NOTIFICATIONS COLLECTION
    // ================================
    match /notifications/{notificationId} {
      // Users can read their own notifications
      allow read: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      
      // Authenticated users can create notifications
      allow create: if isAuthenticated() &&
        request.resource.data.userId is string &&
        request.resource.data.type is string &&
        request.resource.data.title is string &&
        request.resource.data.message is string &&
        request.resource.data.isRead is bool &&
        request.resource.data.createdAt is timestamp;
      
      // Users can update/delete their own notifications
      allow update, delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
    }
    
    // ================================
    // EVENTS COLLECTION
    // ================================
    match /events/{eventId} {
      // Anyone authenticated can create events
      allow create: if isAuthenticated();
      
      // Only admins can read/update/delete events
      allow read, update, delete: if false;
    }
    
    // ================================
    // PRODUCTS COLLECTION (Distributor Products)
    // ================================
    match /products/{productId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() &&
        request.auth.uid == resource.data.distributorId;
    }
    
    // ================================
    // DEFAULT DENY
    // ================================
    // Deny access to any other collections not explicitly defined
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

